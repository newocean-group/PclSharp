<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
    <metadata>
        <id>PclSharp</id>
        <version>1.0.0</version>
        <title>PclSharp</title>
        <authors>Newocean</authors>
        <owners>Newocean</owners>
        <description>.NET 4.8 P/Invoke bindings for the Point Cloud Library (PCL). Requires PclSharp.Runtime.x64 for native DLLs.</description>
        <tags>pcl point-cloud binding pinvoke</tags>
        <dependencies>
            <group targetFramework="net48">
                <dependency id="PclSharp.Runtime.x64" version="1.0.0" />
                <dependency id="System.Numerics.Vectors" version="4.4.0" exclude="Build,Analyzers" />
                <dependency id="System.Runtime.CompilerServices.Unsafe" version="4.4.0" exclude="Build,Analyzers" />
                <dependency id="System.ValueTuple" version="4.4.0" exclude="Build,Analyzers" />
            </group>
        </dependencies>
    </metadata>
    <files>
        <!-- Managed assembly -->
        <file src="..\bin\x64\Release\PclSharp.dll" target="lib\net48" />

        <!-- MSBuild targets stub (required by NuGet; no build actions needed — runtime package handles native DLLs) -->
        <file src="PclSharp.targets" target="build\PclSharp.targets" />
    </files>
</package>
