<Window x:Class="PclSharpWpfTest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PclSharp WPF Test Application"
        Width="1150"
        Height="720"
        MinWidth="900"
        MinHeight="540"
        ResizeMode="CanResizeWithGrip"
        Background="#F5F5F5">

    <DockPanel>

        <!-- ============================================================ -->
        <!-- STATUS BAR -->
        <!-- ============================================================ -->
        <StatusBar DockPanel.Dock="Bottom"
                   Background="#E0E0E0"
                   BorderThickness="0,1,0,0"
                   BorderBrush="#BDBDBD">
            <StatusBarItem HorizontalContentAlignment="Stretch">
                <TextBlock x:Name="TxtStatus"
                           Text="Ready."
                           VerticalAlignment="Center"
                           Padding="4,0" />
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="PclSharp v1.0 | .NET 4.8 | x64"
                           Foreground="#757575"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Padding="4,0" />
            </StatusBarItem>
        </StatusBar>

        <!-- ============================================================ -->
        <!-- BOTTOM BUTTON ROW -->
        <!-- ============================================================ -->
        <Border DockPanel.Dock="Bottom"
                Background="#EEEEEE"
                BorderThickness="0,1,0,0"
                BorderBrush="#BDBDBD"
                Padding="8,6">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="BtnClear"
                        Content="Clear Output"
                        Margin="0,0,8,0"
                        Padding="14,6"
                        MinWidth="120"
                        Click="BtnClear_Click" />
                <Button x:Name="BtnRunAll"
                        Content="Run All Tests"
                        Padding="14,6"
                        MinWidth="140"
                        Click="BtnRunAll_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#0078D4" />
                            <Setter Property="Foreground" Value="White" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="2"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#006CBE" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Background" Value="#005A9E" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>

        <!-- ============================================================ -->
        <!-- MAIN: Left control panel + Right 3D viewport                 -->
        <!-- ============================================================ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" MinWidth="280" MaxWidth="440" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ======================================================== -->
            <!-- LEFT PANEL: Controls + Output Log                        -->
            <!-- ======================================================== -->
            <Border Grid.Column="0"
                    BorderThickness="0,0,1,0"
                    BorderBrush="#BDBDBD">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="12,10,12,10">

                        <!-- Header -->
                        <TextBlock Text="PclSharp Test Application"
                                   FontSize="17"
                                   FontWeight="Bold"
                                   Foreground="#212121"
                                   Margin="0,0,0,2" />
                        <TextBlock Text="Load, process, and visualize point clouds"
                                   FontSize="12"
                                   Foreground="#616161"
                                   Margin="0,0,0,8" />
                        <Separator Margin="0,0,0,10" Background="#BDBDBD" />

                        <!-- ============================================ -->
                        <!-- GROUP: Synthetic Cloud Tests                 -->
                        <!-- ============================================ -->
                        <GroupBox Margin="0,0,0,8"
                                  Padding="8,6,8,8"
                                  BorderBrush="#BDBDBD">
                            <GroupBox.Header>
                                <TextBlock Text="Synthetic Cloud Tests" FontWeight="SemiBold" FontSize="12" />
                            </GroupBox.Header>
                            <WrapPanel Orientation="Horizontal">
                                <Button x:Name="BtnCreateCloud"
                                        Content="1. Create Cloud (1000 pts)"
                                        Margin="3"
                                        Padding="8,5"
                                        MinWidth="150"
                                        Click="BtnCreateCloud_Click" />
                                <Button x:Name="BtnVoxelGrid"
                                        Content="2. VoxelGrid (leaf=0.05)"
                                        Margin="3"
                                        Padding="8,5"
                                        MinWidth="150"
                                        Click="BtnVoxelGrid_Click" />
                                <Button x:Name="BtnSOR"
                                        Content="3. Stat. Outlier Removal"
                                        Margin="3"
                                        Padding="8,5"
                                        MinWidth="150"
                                        Click="BtnSOR_Click" />
                                <Button x:Name="BtnRANSAC"
                                        Content="4. RANSAC Plane Seg."
                                        Margin="3"
                                        Padding="8,5"
                                        MinWidth="150"
                                        Click="BtnRANSAC_Click" />
                                <Button x:Name="BtnClustering"
                                        Content="5. Euclidean Clustering"
                                        Margin="3"
                                        Padding="8,5"
                                        MinWidth="150"
                                        Click="BtnClustering_Click" />
                            </WrapPanel>
                        </GroupBox>

                        <!-- ============================================ -->
                        <!-- GROUP: File I/O                              -->
                        <!-- ============================================ -->
                        <GroupBox Margin="0,0,0,8"
                                  Padding="8,6,8,8"
                                  BorderBrush="#BDBDBD">
                            <GroupBox.Header>
                                <TextBlock Text="File I/O" FontWeight="SemiBold" FontSize="12" />
                            </GroupBox.Header>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- PCD Load row -->
                                <DockPanel Grid.Row="0" Margin="0,0,0,5">
                                    <Button x:Name="BtnBrowsePcd"
                                            Content="Browse"
                                            DockPanel.Dock="Right"
                                            Margin="4,0,0,0"
                                            Padding="8,5"
                                            MinWidth="60"
                                            Click="BtnBrowsePcd_Click" />
                                    <Button x:Name="BtnLoadPcd"
                                            Content="Load PCD"
                                            DockPanel.Dock="Right"
                                            Margin="4,0,0,0"
                                            Padding="8,5"
                                            MinWidth="75"
                                            Click="BtnLoadPcd_Click" />
                                    <TextBox x:Name="TxtPcdPath"
                                             VerticalContentAlignment="Center"
                                             Padding="5,4"
                                             FontSize="11">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Style.Resources>
                                                    <VisualBrush x:Key="PlaceholderPcd"
                                                                 AlignmentX="Left"
                                                                 AlignmentY="Center"
                                                                 Stretch="None">
                                                        <VisualBrush.Visual>
                                                            <TextBlock Text="Select a .pcd file..."
                                                                       Foreground="#9E9E9E"
                                                                       FontSize="11"
                                                                       Margin="5,0,0,0" />
                                                        </VisualBrush.Visual>
                                                    </VisualBrush>
                                                </Style.Resources>
                                                <Style.Triggers>
                                                    <Trigger Property="Text" Value="">
                                                        <Setter Property="Background" Value="{StaticResource PlaceholderPcd}" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </DockPanel>

                                <!-- OBJ Load row -->
                                <DockPanel Grid.Row="1" Margin="0,0,0,5">
                                    <Button x:Name="BtnBrowseObj"
                                            Content="Browse"
                                            DockPanel.Dock="Right"
                                            Margin="4,0,0,0"
                                            Padding="8,5"
                                            MinWidth="60"
                                            Click="BtnBrowseObj_Click" />
                                    <Button x:Name="BtnLoadObj"
                                            Content="Load OBJ"
                                            DockPanel.Dock="Right"
                                            Margin="4,0,0,0"
                                            Padding="8,5"
                                            MinWidth="75"
                                            Click="BtnLoadObj_Click" />
                                    <TextBox x:Name="TxtObjPath"
                                             VerticalContentAlignment="Center"
                                             Padding="5,4"
                                             FontSize="11">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Style.Resources>
                                                    <VisualBrush x:Key="PlaceholderObj"
                                                                 AlignmentX="Left"
                                                                 AlignmentY="Center"
                                                                 Stretch="None">
                                                        <VisualBrush.Visual>
                                                            <TextBlock Text="Select a .obj file..."
                                                                       Foreground="#9E9E9E"
                                                                       FontSize="11"
                                                                       Margin="5,0,0,0" />
                                                        </VisualBrush.Visual>
                                                    </VisualBrush>
                                                </Style.Resources>
                                                <Style.Triggers>
                                                    <Trigger Property="Text" Value="">
                                                        <Setter Property="Background" Value="{StaticResource PlaceholderObj}" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </DockPanel>

                                <!-- Save PCD row -->
                                <DockPanel Grid.Row="2">
                                    <Button x:Name="BtnSavePcd"
                                            Content="Save as PCD"
                                            DockPanel.Dock="Right"
                                            Margin="4,0,0,0"
                                            Padding="8,5"
                                            MinWidth="90"
                                            Click="BtnSavePcd_Click" />
                                    <TextBox x:Name="TxtSavePath"
                                             IsReadOnly="True"
                                             VerticalContentAlignment="Center"
                                             Padding="5,4"
                                             FontSize="11"
                                             Background="#F5F5F5">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Style.Resources>
                                                    <VisualBrush x:Key="PlaceholderSave"
                                                                 AlignmentX="Left"
                                                                 AlignmentY="Center"
                                                                 Stretch="None">
                                                        <VisualBrush.Visual>
                                                            <TextBlock Text="No file saved yet..."
                                                                       Foreground="#9E9E9E"
                                                                       FontSize="11"
                                                                       Margin="5,0,0,0" />
                                                        </VisualBrush.Visual>
                                                    </VisualBrush>
                                                </Style.Resources>
                                                <Style.Triggers>
                                                    <Trigger Property="Text" Value="">
                                                        <Setter Property="Background" Value="{StaticResource PlaceholderSave}" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>
                                </DockPanel>

                            </Grid>
                        </GroupBox>

                        <!-- ============================================ -->
                        <!-- GROUP: 3D Algorithms                         -->
                        <!-- ============================================ -->
                        <GroupBox Margin="0,0,0,8"
                                  Padding="8,6,8,8"
                                  BorderBrush="#BDBDBD">
                            <GroupBox.Header>
                                <TextBlock Text="3D Algorithms" FontWeight="SemiBold" FontSize="12" />
                            </GroupBox.Header>
                            <WrapPanel Orientation="Horizontal">
                                <Button x:Name="BtnCloudStats"
                                        Content="6. Cloud Statistics"
                                        Margin="3"
                                        Padding="8,5"
                                        MinWidth="140"
                                        Click="BtnCloudStats_Click" />
                                <Button x:Name="BtnConvexHull"
                                        Content="7. Convex Hull"
                                        Margin="3"
                                        Padding="8,5"
                                        MinWidth="140"
                                        Click="BtnConvexHull_Click" />
                                <Button x:Name="BtnIcpSelfTest"
                                        Content="8. ICP Self-Align"
                                        Margin="3"
                                        Padding="8,5"
                                        MinWidth="140"
                                        Click="BtnIcpSelfTest_Click" />
                                <Button x:Name="BtnLoadIcpTarget"
                                        Content="Load ICP Target..."
                                        Margin="3"
                                        Padding="8,5"
                                        MinWidth="140"
                                        Click="BtnLoadIcpTarget_Click" />
                                <Button x:Name="BtnRunIcp"
                                        Content="9. Run ICP (Source→Target)"
                                        Margin="3"
                                        Padding="8,5"
                                        MinWidth="180"
                                        Click="BtnRunIcp_Click" />
                            </WrapPanel>
                        </GroupBox>

                        <!-- ============================================ -->
                        <!-- OUTPUT LOG                                   -->
                        <!-- ============================================ -->
                        <TextBlock Text="Output Log:"
                                   FontWeight="SemiBold"
                                   FontSize="12"
                                   Margin="0,0,0,3" />
                        <ScrollViewer x:Name="OutputScrollViewer"
                                      Height="200"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto"
                                      BorderBrush="#BDBDBD"
                                      BorderThickness="1">
                            <TextBox x:Name="TxtOutput"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     FontFamily="Consolas"
                                     FontSize="11"
                                     Background="#1E1E1E"
                                     Foreground="#D4D4D4"
                                     BorderThickness="0"
                                     Padding="8"
                                     TextWrapping="NoWrap"
                                     CaretBrush="#D4D4D4"
                                     SelectionBrush="#264F78" />
                        </ScrollViewer>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ======================================================== -->
            <!-- RIGHT PANEL: 3D Viewport                                 -->
            <!-- ======================================================== -->
            <Grid x:Name="ViewportGrid" Grid.Column="1" Background="#111111"
                  SizeChanged="ViewportGrid_SizeChanged">

                <!-- Render surface -->
                <Image x:Name="CloudView"
                       Stretch="Fill"
                       Cursor="SizeAll"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                       MouseDown="CloudView_MouseDown"
                       MouseMove="CloudView_MouseMove"
                       MouseUp="CloudView_MouseUp"
                       MouseWheel="CloudView_MouseWheel"
                       SizeChanged="CloudView_SizeChanged" />

                <!-- Empty state placeholder -->
                <TextBlock x:Name="TxtNoCloud"
                           Text="Load or create a point cloud to view it here"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#444444"
                           FontSize="14" />

                <!-- Camera info overlay (top-right) -->
                <Border HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,8,8,0"
                        Background="#88000000"
                        CornerRadius="3"
                        Padding="6,3">
                    <TextBlock x:Name="TxtCameraInfo"
                               Foreground="#AAAAAA"
                               FontFamily="Consolas"
                               FontSize="11"
                               Text="—" />
                </Border>

                <!-- Reset camera button (top-left) -->
                <Button x:Name="BtnResetCamera"
                        Content="↺ Reset View"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="8,8,0,0"
                        Padding="8,4"
                        FontSize="11"
                        Opacity="0.8"
                        Click="BtnResetCamera_Click" />

                <!-- Viewport label (bottom-left) -->
                <TextBlock Text="3D Viewport  |  Drag: orbit   Scroll: zoom"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Bottom"
                           Margin="8,0,0,8"
                           Foreground="#444444"
                           FontSize="11" />

            </Grid>

        </Grid>
    </DockPanel>

</Window>
